# X 平台认证 Cookie（必须）
# 从浏览器开发者工具 → Network → 任意请求的 Request Headers 中复制
X_COOKIE=auth_token=xxx; ct0=xxx; ...

# X API Bearer Token（可选，使用官方 API 时需要）
# X_BEARER_TOKEN=

# 下载目录（默认 ./downloads）
# DOWNLOAD_DIR=./downloads

# HTTP 超时毫秒（默认 30000）
# HTTP_TIMEOUT=30000

# 请求间隔毫秒（默认 2000）
# REQUEST_DELAY=2000

# 调试模式
# DEBUG=true
